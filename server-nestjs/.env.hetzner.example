# =============================================================
# PingUp - Hetzner Cloud Environment (CX23: 2 vCPU, 4GB RAM)
# Copy to /opt/pingup/.env.production and fill in real values
# =============================================================

# Application
NODE_ENV=production
APP_PORT=4000
NOTIFICATION_PORT=4001
CRONJOB_PORT=4002

# Database - PostgreSQL (container internal)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=pingup_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=pingup
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# JWT
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET_256_BITS
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_SECURE_REFRESH_SECRET_256_BITS
JWT_ACCESS_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# Redis (container internal)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# AWS S3
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET=pingup-uploads
AWS_PUBLIC_URL_BASE=https://pingup-uploads.s3.ap-southeast-1.amazonaws.com

# ImageKit
IMAGEKIT_PUBLIC_KEY=CHANGE_ME
IMAGEKIT_PRIVATE_KEY=CHANGE_ME
IMAGEKIT_URL_ENDPOINT=CHANGE_ME

# File Upload Limits
MAX_IMAGE_SIZE=10485760
MAX_FILES_PER_UPLOAD=10

# Email (Gmail SMTP)
GMAIL_USER=CHANGE_ME
GMAIL_APP_PASS=CHANGE_ME

# Groq AI (Speech-to-Text)
GROQ_API_KEY=CHANGE_ME

# Frontend URL (your Vercel domain)
FRONTEND_URL=https://pingup.cheaptest.online

# Docker Registry (your Docker Hub username)
REGISTRY=CHANGE_ME
VERSION=latest
